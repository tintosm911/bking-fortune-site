generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  charts          Chart[]
  orders          Order[]   @relation("UserOrders")
  referredOrders  Order[]   @relation("RefOrders")
  partner         Partner?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  sessionState      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Chart {
  id        String   @id @default(cuid())
  userId    String
  name      String
  birth     String
  time      String   @default("12:00")
  gender    String   @default("male")
  city      String?
  data      String
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("charts")
}

model Order {
  id         String    @id @default(cuid())
  userId     String?
  email      String?
  product    String
  amount     Float
  currency   String    @default("usd")
  status     String    @default("paid")
  sessionId  String?
  referrerId String?
  commission Float?
  chartId    String?
  createdAt  DateTime  @default(now())

  user     User?   @relation("UserOrders", fields: [userId], references: [id])
  referrer User?   @relation("RefOrders", fields: [referrerId], references: [id])
  chart    Chart?  @relation(fields: [chartId], references: [id])

  @@map("orders")
}

model Partner {
  id          String   @id @default(cuid())
  userId      String   @unique
  refCode     String   @unique
  socialLinks String?
  tier        String   @default("bronze")
  totalSales  Float    @default(0)
  commission  Float    @default(0)
  balance     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  referrals   Referral[]
  commissions Commission[]

  @@map("partners")
}

model Referral {
  id        String   @id @default(cuid())
  partnerId String
  visitorId String?  // anonymous fingerprint or User.id after conversion
  ip        String?
  userAgent String?
  converted Boolean  @default(false)
  createdAt DateTime @default(now())

  partner Partner @relation(fields: [partnerId], references: [id])

  @@map("referrals")
}

model Commission {
  id        String    @id @default(cuid())
  partnerId String
  orderId   String
  amount    Float
  status    String    @default("pending")
  createdAt DateTime  @default(now())
  paidAt    DateTime?

  partner Partner @relation(fields: [partnerId], references: [id])

  @@map("commissions")
}
